# FinSight AI — Next.js environment template
# Copy to apps/web/.env.local for local development.
# For production, set these in the Vercel project dashboard.

# Clerk (public key is safe in the browser)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Clerk server key for Next.js server components (never expose to client bundles)
CLERK_SECRET_KEY=

# Clerk sign-in/up routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# FastAPI backend URL
# Local: http://localhost:8000
# Production: https://your-render-service.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000
