# =============================================================================
# FinSight AI — environment template
# Copy to `.env` at the repo root for local API development.
# For production, set these on Render (backend). Do not commit real secrets.
# =============================================================================

# --- Database (required for API) ---
# Local Docker Compose default:
DATABASE_URL=postgresql+psycopg://finsight:finsight_password@localhost:5432/finsight_db
# Production: use your managed PostgreSQL URL (postgresql:// or postgresql+psycopg://)

# --- CORS / frontend origin (required for production API) ---
# Exact URL of the deployed Next.js app (no trailing slash), e.g. https://finsight.vercel.app
FRONTEND_URL=

# --- Auth (Clerk) — backend JWT verification ---
CLERK_SECRET_KEY=
CLERK_JWKS_URL=

# --- AI (OpenAI) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_ENABLED=false

# --- Embeddings (OpenAI + pgvector) ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDINGS_ENABLED=false

# =============================================================================
# Local development only (Docker Compose)
# =============================================================================
POSTGRES_USER=finsight
POSTGRES_PASSWORD=finsight_password
POSTGRES_DB=finsight_db
REDIS_URL=redis://localhost:6379/0
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# Frontend (Next.js) — set in apps/web/.env.local locally or Vercel dashboard
# NEXT_PUBLIC_* values are exposed to the browser. Never put secrets there.
# =============================================================================
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# NEXT_PUBLIC_API_URL=http://localhost:8000
# CLERK_SECRET_KEY=  (server-only, required for Next.js Clerk components)
